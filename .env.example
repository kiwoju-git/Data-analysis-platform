# DataLab Studio local development settings.
# Do not put secrets or user data in this file.

DATALAB_ENVIRONMENT=development
DATALAB_BIND_HOST=127.0.0.1
DATALAB_BIND_PORT=8000
DATALAB_MAX_UPLOAD_BYTES=104857600

# Optional. Leave blank to use %LOCALAPPDATA%\DataLabStudio on Windows.
# DATALAB_WORKSPACE_ROOT=
